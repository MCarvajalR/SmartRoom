# Copia este archivo como .env.simulated y completa los valores locales.
# No guardes tokens reales en Git.

DB_NAME=smartroom_db
DB_USER=smartroom_user
DB_PASSWORD=smartroom_password

JWT_SECRET_KEY=change-me-for-local-simulated
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Home Assistant simulado/remoto de pruebas.
# Ejemplo: http://100.x.x.x:8123, http://192.168.x.x:8123 o una URL HTTPS.
HA_URL=http://SIMULATED_HOME_ASSISTANT_HOST:8123
HA_PUBLIC_URL=http://SIMULATED_HOME_ASSISTANT_HOST:8123
HA_TOKEN=PASTE_SIMULATED_LONG_LIVED_ACCESS_TOKEN_HERE

TELEMETRY_INTERVAL_SECONDS=60

# Importacion inicial del historial desde el HA simulado.
HA_HISTORY_BACKFILL_ENABLED=true
HA_HISTORY_BACKFILL_DAYS=30
HA_HISTORY_BACKFILL_CHUNK_HOURS=24
