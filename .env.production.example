# Copia este archivo como .env.production o .env en el servidor.
# Mantener tokens y contrasenas fuera de Git.

DB_NAME=smartroom_db
DB_USER=smartroom_user
DB_PASSWORD=change-me

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Home Assistant real de la universidad.
HA_URL=http://REAL_HOME_ASSISTANT_HOST:8123
HA_PUBLIC_URL=http://REAL_HOME_ASSISTANT_HOST:8123
HA_TOKEN=PASTE_REAL_LONG_LIVED_ACCESS_TOKEN_HERE

TELEMETRY_INTERVAL_SECONDS=60

# Puedes dejarlo true para importar historial al primer despliegue.
# Si quieren evitar cualquier carga extra sobre el HA real, usar false.
HA_HISTORY_BACKFILL_ENABLED=true
HA_HISTORY_BACKFILL_DAYS=30
HA_HISTORY_BACKFILL_CHUNK_HOURS=24
